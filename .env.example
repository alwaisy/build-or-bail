# App
PORT=5897
SHOW_MOCK=false
LLM_PROVIDER=openrouter

# LLM Providers (at least one required)
OPENROUTER_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_MODEL=gemini-3.1-flash-lite
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# Reddit Discovery
# Optional: Proxy for Reddit scraping (e.g., http://user:pass@host:port)
PROXY_URL=

# Vertex AI (requires service account JSON for server deployment)
# Path to the JSON file (e.g., google-creds.json)
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT_ID=
VERTEX_REGION=us-central1

# Turso SQLite (optional - for persisting saved ideas)
TURSO_DB_URL=
TURSO_AUTH_TOKEN=
